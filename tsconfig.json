{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "astro.config.mjs", "playwright.config.ts"],
  "exclude": [
    "2019",
    "2020",
    "about",
    "archives",
    "categories",
    "css",
    "images",
    "js",
    "lib",
    "page",
    "public",
    "tags",
    "dist",
    "node_modules"
  ]
}
