---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChannelHero from "../../components/site/ChannelHero.astro";
import { getCollectionSlug, getLabEntries, type LabEntry } from "../../lib/content/posts";
import { getSectorGraph } from "../../lib/theme-sectors/get-sector-graph";
import { getCarrierSectors } from "../../lib/theme-sectors/sector-presenters";
import { siteMeta } from "../../data/site";

const entries = await getLabEntries();
const readyCount = entries.filter((entry) => entry.data.status === "ready").length;
const statsCount = entries.filter((entry) => entry.data.kind === "stats").length;
const sectorGraph = await getSectorGraph();
const carrierSectors = getCarrierSectors(sectorGraph.sectors, "lab");
---

<BaseLayout
  title={`实验 | ${siteMeta.title}`}
  description="这里放的是轻量交互表达、统计视图和展示型 demo。"
  path="/lab"
>
  <ChannelHero
    pathLabel="实验"
    eyebrow="Interaction Layer"
    title="实验"
    summary="这里是主题战区下的实验资产载体，用来承接图表、交互表达和展示型验证入口。"
    chips={[
      ...carrierSectors.map((sector) => ({ label: sector.title, href: `/sectors/${sector.slug}/` })),
      ...entries.map((entry) => ({ label: entry.data.kind, href: `/lab/${getCollectionSlug(entry)}/` }))
    ]}
    metrics={[
      { label: "实验数量", value: entries.length },
      { label: "可直接查看", value: readyCount },
      { label: "统计视图", value: statsCount },
      { label: "展示原型", value: entries.length - statsCount }
    ]}
    noteTitle="Lab Note"
    note="实验页现在服务于战区表达：它不是独立产品区，而是帮助某个主题战区把结果、节奏和验证方式展示得更清楚。"
  />

  <section class="page-section panel">
    <div class="section-head">
      <div>
        <h2>实验入口</h2>
        <p>优先放那些确实适合用交互、图表或切换态来解释的内容。</p>
      </div>
    </div>
    <div class="card-grid">
      {entries.map((entry: LabEntry) => (
        <article class="content-card content-card--signal">
          <div class="archive-card__head">
            <span class="card-kicker">Lab Entry</span>
            <span class="meta-chip">{entry.data.status}</span>
          </div>
          <h3 class="archive-card__title">
            <a href={`/lab/${getCollectionSlug(entry)}/`}>{entry.data.title}</a>
          </h3>
          <p class="archive-card__summary">{entry.data.description}</p>
          <div class="meta-row">
            <span class="meta-chip">{entry.data.kind}</span>
            <span class="meta-chip meta-chip--soft">{entry.data.featured ? "重点入口" : "扩展入口"}</span>
          </div>
          <div class="archive-card__footer">
            <span class="archive-card__source">交互表达</span>
            <a class="archive-card__link" href={`/lab/${getCollectionSlug(entry)}/`}>
              打开实验
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
