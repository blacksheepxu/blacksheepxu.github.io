---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryDetailShell from "../../components/site/EntryDetailShell.astro";
import { getCollectionSlug, getPosts, type LabEntry } from "../../lib/content/posts";
import { buildSiteStats } from "../../lib/stats/site-stats";
import { getSectorGraph } from "../../lib/theme-sectors/get-sector-graph";
import { resolveAssetSectorContext } from "../../lib/theme-sectors/sector-presenters";
import CadenceSummary from "../../components/stats/CadenceSummary.astro";
import TopicDistributionSummary from "../../components/stats/TopicDistributionSummary.astro";
import ParameterDemoShell from "../../components/interactive/ParameterDemoShell.astro";

interface Props {
  entry: LabEntry;
}

export const getStaticPaths = (async () => {
  const entries = await getCollection("lab");
  return entries.map((entry: LabEntry) => ({
    params: { slug: getCollectionSlug(entry) },
    props: { entry }
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const posts = await getPosts();
const stats = buildSiteStats(posts);
const sectorGraph = await getSectorGraph();
const { relatedSectors } = resolveAssetSectorContext(sectorGraph.sectors, `/lab/${getCollectionSlug(entry)}/`);
const statusLabelMap: Record<LabEntry["data"]["status"], string> = {
  ready: "可直接查看",
  prototype: "原型阶段",
  planned: "计划阶段"
};
---

<BaseLayout title={`${entry.data.title} | 实验`} description={entry.data.description} path="/lab">
  <EntryDetailShell
    title={entry.data.title}
    summary={entry.data.description}
    eyebrow="Lab Detail"
    pathTrail={[
      { label: "实验", href: "/lab" },
      { label: entry.data.title }
    ]}
    chips={[
      ...relatedSectors.map((sector) => ({ label: sector.title, href: `/sectors/${sector.slug}/` })),
      { label: entry.data.kind },
      { label: entry.data.status }
    ]}
    metrics={[
      { label: "实验类型", value: entry.data.kind },
      { label: "当前状态", value: entry.data.status },
      { label: "重点入口", value: entry.data.featured ? "是" : "否" },
      { label: "内容来源", value: "交互表达" }
    ]}
    noteTitle="Lab Detail"
    note="实验详情页作为战区资产的一种特殊表面存在：它负责展示交互表达与验证方式，而不替代战区层的总控语义。"
    contextTitle="Carrier Route"
    contextSummary="这是一份阅读与体验优先的实验卷宗。当前实验载体更像战区内的验证入口，而不是独立实验平台。"
    contextChips={[
      { label: "实验载体" },
      { label: statusLabelMap[entry.data.status] },
      ...relatedSectors.map((sector) => ({ label: sector.title, href: `/sectors/${sector.slug}/` })),
      { label: entry.data.kind }
    ]}
  >
    <Content />
  </EntryDetailShell>

  <section class="page-section panel">
    <div class="section-head">
      <div>
        <h2>轻量交互示例</h2>
        <p>这部分演示第一版交互的边界：支持理解，不喧宾夺主。</p>
      </div>
    </div>
    <div class="card-grid">
      <CadenceSummary buckets={stats.cadence} />
      <TopicDistributionSummary buckets={stats.topics} />
    </div>
    <div style="margin-top: 1rem">
      <ParameterDemoShell />
    </div>
  </section>
</BaseLayout>
