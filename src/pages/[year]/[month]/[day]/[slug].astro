---
import { render } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ArticleShell from "../../../../components/site/ArticleShell.astro";
import { getLegacyStaticPaths, getPosts, type PostEntry } from "../../../../lib/content/posts";

interface Props {
  post: PostEntry;
}

export async function getStaticPaths() {
  return getLegacyStaticPaths(await getPosts());
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | 博客`} description={post.data.description} path="/blog">
  <ArticleShell post={post}>
    <div class="prose">
      <Content />
    </div>
  </ArticleShell>
</BaseLayout>
