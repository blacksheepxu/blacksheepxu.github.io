---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryDetailShell from "../../components/site/EntryDetailShell.astro";
import { getCollectionSlug, type ResearchEntry } from "../../lib/content/posts";

interface Props {
  entry: ResearchEntry;
}

export const getStaticPaths = (async () => {
  const entries = await getCollection("research");
  return entries.map((entry: ResearchEntry) => ({
    params: { slug: getCollectionSlug(entry) },
    props: { entry }
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | 研究`} description={entry.data.description} path="/research">
  <EntryDetailShell
    title={entry.data.title}
    summary={entry.data.description}
    eyebrow="Research Detail"
    pathTrail={[
      { label: "研究", href: "/research" },
      { label: entry.data.title }
    ]}
    chips={[
      { label: entry.data.focus },
      { label: entry.data.status }
    ]}
    metrics={[
      { label: "研究焦点", value: entry.data.focus },
      { label: "当前状态", value: entry.data.status },
      { label: "关联文章", value: entry.data.relatedPosts.length },
      { label: "显示优先级", value: entry.data.order }
    ]}
    noteTitle="Research Detail"
    note="研究详情页负责更完整地解释一个方向，而不是只留下卡片级摘要。"
  >
    <Content />
  </EntryDetailShell>
</BaseLayout>
