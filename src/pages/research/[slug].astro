---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryDetailShell from "../../components/site/EntryDetailShell.astro";
import { getCollectionSlug, type ResearchEntry } from "../../lib/content/posts";
import { getSectorGraph } from "../../lib/theme-sectors/get-sector-graph";
import { resolveAssetSectorContext } from "../../lib/theme-sectors/sector-presenters";

interface Props {
  entry: ResearchEntry;
}

export const getStaticPaths = (async () => {
  const entries = await getCollection("research");
  return entries.map((entry: ResearchEntry) => ({
    params: { slug: getCollectionSlug(entry) },
    props: { entry }
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const sectorGraph = await getSectorGraph();
const { relatedSectors } = resolveAssetSectorContext(sectorGraph.sectors, `/research/${getCollectionSlug(entry)}/`);
---

<BaseLayout title={`${entry.data.title} | 研究`} description={entry.data.description} path="/research">
  <EntryDetailShell
    title={entry.data.title}
    summary={entry.data.description}
    eyebrow="Research Detail"
    pathTrail={[
      { label: "研究", href: "/research" },
      { label: entry.data.title }
    ]}
    chips={[
      ...relatedSectors.map((sector) => ({ label: sector.title, href: `/sectors/${sector.slug}/` })),
      { label: entry.data.focus },
      { label: entry.data.status }
    ]}
    metrics={[
      { label: "研究焦点", value: entry.data.focus },
      { label: "当前状态", value: entry.data.status },
      { label: "关联文章", value: entry.data.relatedPosts.length },
      { label: "显示优先级", value: entry.data.order }
    ]}
    noteTitle="Research Detail"
    note="研究详情页现在承担战区资产说明角色：它不替代战区总览，而是为某条主题线补足完整背景与长期说明。"
  >
    <Content />
  </EntryDetailShell>
</BaseLayout>
