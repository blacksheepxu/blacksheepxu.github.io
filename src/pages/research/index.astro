---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChannelHero from "../../components/site/ChannelHero.astro";
import ResearchCard from "../../components/research/ResearchCard.astro";
import ResearchTimeline from "../../components/research/ResearchTimeline.astro";
import ResearchModeSwitcher from "../../components/research/ResearchModeSwitcher.astro";
import { buildTaxonomyMap, getCollectionSlug, getPosts, getResearchEntries, type ResearchEntry } from "../../lib/content/posts";
import { getSectorGraph } from "../../lib/theme-sectors/get-sector-graph";
import { getCarrierSectors } from "../../lib/theme-sectors/sector-presenters";
import { siteMeta } from "../../data/site";

const [entries, posts] = await Promise.all([getResearchEntries(), getPosts()]);
const activeEntries = entries.filter((entry) => entry.data.status === "active").length;
const topicCount = buildTaxonomyMap(posts, "categories").length;
const sectorGraph = await getSectorGraph();
const carrierSectors = getCarrierSectors(sectorGraph.sectors, "research");
---

<BaseLayout
  title={`研究 | ${siteMeta.title}`}
  description="研究方向、方法和代表内容。"
  path="/research"
>
  <ChannelHero
    pathLabel="研究"
    eyebrow="Research Modes"
    title="研究"
    summary="这里现在是主题战区下的研究资产载体，用来承接长期方向、方法说明和代表性研究条目。"
    chips={[
      ...carrierSectors.map((sector) => ({ label: sector.title, href: `/sectors/${sector.slug}/` })),
      ...entries.map((entry) => ({ label: entry.data.focus, href: `/research/${getCollectionSlug(entry)}/` }))
    ]}
    metrics={[
      { label: "研究轨道", value: entries.length },
      { label: "活跃方向", value: activeEntries },
      { label: "相关文章", value: posts.length },
      { label: "主题分类", value: topicCount }
    ]}
    noteTitle="Research Note"
    note="研究页不再是首页主叙事，而是策略主题下的研究资产表面：用于补足战区的长期方向说明与结构化背景。"
  />

  <div class="theme-shell--content">
    <section class="page-section panel">
      <div class="section-head">
        <div>
          <h2>研究版图</h2>
          <p>每一条研究轨道都尽量说明主题、当前状态和继续展开的入口。</p>
        </div>
      </div>
      <div class="card-grid">
        {entries.map((entry: ResearchEntry) => <ResearchCard entry={entry} />)}
      </div>
    </section>

    <section class="page-section panel">
      <div class="section-head">
        <div>
          <h2>最近的内容轨迹</h2>
          <p>按时间查看研究内容如何继续增长，而不是只看单次输出。</p>
        </div>
      </div>
      <ResearchTimeline posts={posts} />
    </section>
  </div>

  <ResearchModeSwitcher entries={entries} posts={posts} />
</BaseLayout>
