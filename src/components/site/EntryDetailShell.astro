---
import ChannelHero from "./ChannelHero.astro";

interface Chip {
  label: string;
  href?: string;
}

interface TrailItem {
  label: string;
  href?: string;
}

interface Metric {
  label: string;
  value: string | number;
}

interface Props {
  title: string;
  summary: string;
  eyebrow: string;
  pathTrail: TrailItem[];
  chips?: Chip[];
  metrics?: Metric[];
  noteTitle?: string;
  note?: string;
  contextTitle?: string;
  contextSummary?: string;
  contextChips?: Chip[];
  bodyClass?: string;
}

const {
  title,
  summary,
  eyebrow,
  pathTrail,
  chips = [],
  metrics = [],
  noteTitle = "Detail Note",
  note,
  contextTitle = "Carrier Route",
  contextSummary,
  contextChips = [],
  bodyClass = "prose"
} = Astro.props as Props;
---

<ChannelHero
  pathTrail={pathTrail}
  eyebrow={eyebrow}
  title={title}
  summary={summary}
  chips={chips}
  metrics={metrics}
  noteTitle={noteTitle}
  note={note}
/>

{(contextSummary || contextChips.length > 0) && (
  <section class="page-section panel detail-route-panel">
    <div class="detail-route-panel__head">
      <span class="card-kicker">{contextTitle}</span>
      {contextSummary && <p>{contextSummary}</p>}
    </div>
    {contextChips.length > 0 && (
      <div class="article-taxonomy">
        {contextChips.map((chip) =>
          chip.href ? (
            <a class="meta-chip" href={chip.href}>
              {chip.label}
            </a>
          ) : (
            <span class="meta-chip meta-chip--soft">{chip.label}</span>
          )
        )}
      </div>
    )}
  </section>
)}

<article class="page-section panel">
  <div class={bodyClass}>
    <slot />
  </div>
</article>
