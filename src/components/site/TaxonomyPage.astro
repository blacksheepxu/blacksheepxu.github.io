---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChannelHero from "./ChannelHero.astro";
import { getPostHref, type PostEntry } from "../../lib/content/posts";

interface TaxonomyItem {
  name: string;
  items: PostEntry[];
}

interface Props {
  item: TaxonomyItem;
  label: string;
  description: string;
}

const { item, label, description } = Astro.props;
const sortedItems = [...item.items].sort((left, right) => right.data.pubDate.getTime() - left.data.pubDate.getTime());
const newestPost = sortedItems[0];
const legacyCount = item.items.filter((post) => post.data.source === "legacy").length;
const themeRole = label === "标签" ? "跨主题线索" : "主主题分卷";
const routeSummary =
  label === "标签"
    ? "适合先看最近更新，再决定是否回到博客总库继续扩展阅读。"
    : "适合作为一个主主题分卷来连续阅读，再回到博客频道补全外围内容。";
---

<BaseLayout title={`${item.name} | ${label}`} description={`与 ${item.name} 相关的文章集合。`} path="/blog">
  <ChannelHero
    pathTrail={[
      { label: "博客", href: "/blog" },
      { label: `${label}：${item.name}` }
    ]}
    eyebrow={label === "标签" ? "Topic Archive" : "Category Archive"}
    title={`${label}：${item.name}`}
    summary={description}
    chips={[
      { label: item.name },
      { label: `${item.items.length} 篇文章` }
    ]}
    metrics={[
      { label: "相关文章", value: item.items.length },
      { label: "归档文章", value: legacyCount },
      { label: "原生文章", value: item.items.length - legacyCount },
      { label: "最近更新", value: newestPost?.data.pubDate.toISOString().slice(0, 10) ?? "-" }
    ]}
    noteTitle="Archive Note"
    note="这里不是普通分类页，而是博客频道里的单主题分卷入口，用来把同一条线索下的记录重新收拢。"
  />

  <section class="page-section panel taxonomy-intel">
    <div class="section-head">
      <div>
        <h2>分卷定位</h2>
        <p>先知道这个主题在博客体系里扮演什么角色，再决定从哪一篇开始进入。</p>
      </div>
    </div>

    <div class="taxonomy-intel__grid">
      <article class="command-note command-note--emphasis">
        <span class="card-kicker">Theme Role</span>
        <h3>{themeRole}</h3>
        <p>{routeSummary}</p>
      </article>
      <article class="command-note">
        <span class="card-kicker">Recent Activity</span>
        <h3>{newestPost?.data.pubDate.toISOString().slice(0, 10) ?? "-"}</h3>
        <p>{newestPost?.data.title ?? "当前分卷还没有可展示的最近更新。"}</p>
      </article>
      <article class="command-note">
        <span class="card-kicker">Related Routes</span>
        <div class="article-taxonomy">
          <a class="meta-chip" href="/blog">返回博客总库</a>
          {newestPost && (
            <a class="meta-chip meta-chip--soft" href={getPostHref(newestPost)}>
              先看最近一篇
            </a>
          )}
        </div>
      </article>
    </div>
  </section>

  <section class="page-section panel">
    <div class="section-head">
      <div>
        <h2>分卷档案</h2>
        <p>这一批记录属于同一主题线索，适合顺着编号一路读下去。</p>
      </div>
    </div>
    <div class="archive-grid">
      {sortedItems.map((post, index) => (
        <article class={`content-card archive-card ${index === 0 ? "archive-card--priority" : "archive-card--record"} ${post.data.source === "legacy" ? "archive-card--legacy" : "archive-card--native"}`}>
          <div class="archive-card__head">
            <span class="archive-card__stamp">File {String(index + 1).padStart(2, "0")}</span>
            <span class="meta-chip">{post.data.pubDate.toISOString().slice(0, 10)}</span>
          </div>
          <h3 class="archive-card__title">
            <a href={getPostHref(post)}>{post.data.title}</a>
          </h3>
          <p class="archive-card__summary">{post.data.description}</p>
          <div class="meta-row">
            {post.data.categories.slice(0, 2).map((category: string) => (
              <a class="meta-chip" href={`/categories/${encodeURIComponent(category)}/`}>
                {category}
              </a>
            ))}
            {post.data.tags.slice(0, 2).map((tag: string) => (
              <a class="meta-chip meta-chip--soft" href={`/tags/${encodeURIComponent(tag)}/`}>
                #{tag}
              </a>
            ))}
          </div>
          <div class="archive-card__footer">
            <span class="archive-card__source">{post.data.source === "legacy" ? "归档迁移" : "原生发布"}</span>
            <a class="archive-card__link" href={getPostHref(post)}>
              打开文章
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
