---
import { siteMeta } from "../../data/site";

interface NavItem {
  href: string;
  label: string;
  commandCue?: string;
}

interface Props {
  path: string;
  nav: NavItem[];
}

const { path, nav } = Astro.props;
---

<header class="site-header shell">
  <div class="site-header__inner">
    <div class="site-title">
      <a href="/">{siteMeta.title}</a>
    </div>
    <div class="site-nav-group">
      <div class="site-shell-context" aria-live="polite">
        <span class="site-shell-context__label">当前视角</span>
        <strong class="site-shell-context__mode site-shell-context__mode--content">研究网站</strong>
        <strong class="site-shell-context__mode site-shell-context__mode--command">战区总控</strong>
        <span class="site-shell-context__note site-shell-context__note--content">内容优先</span>
        <span class="site-shell-context__note site-shell-context__note--command">主题态势优先</span>
      </div>

      <nav class="site-nav" aria-label="站点导航">
        {
          nav.map((item) => (
            <a href={item.href} aria-current={path === item.href ? "page" : undefined}>
              <span class="site-nav__label">{item.label}</span>
              {item.commandCue && <span class="site-nav__cue">{item.commandCue}</span>}
            </a>
          ))
        }
      </nav>

      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-pressed="false"
        aria-label="切换站点主题"
      >
        <span class="theme-toggle__label" data-theme-toggle-label>主题</span>
        <span class="theme-toggle__state" data-theme-toggle-state>默认</span>
      </button>
    </div>
  </div>
</header>
