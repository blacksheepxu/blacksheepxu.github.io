---
import { isLegacyPost, type PostEntry } from "../../lib/content/posts";
import type { ThemeSector } from "../../lib/theme-sectors/sector-graph";

interface Props {
  post: PostEntry;
  relatedSectors?: ThemeSector[];
}

const { post, relatedSectors = [] } = Astro.props as Props;

const sourceLabel = isLegacyPost(post) ? "归档文章" : "原生文章";
const sourceDescription = isLegacyPost(post) ? "从旧站迁移并重新整理" : "在 Astro 中原生发布";
const dossierLabel = isLegacyPost(post) ? "Archive Dossier" : "Active Dossier";
const readingMinutes = Math.max(
  1,
  Math.round(
    post.body
      .replace(/<[^>]+>/g, " ")
      .replace(/[`#>*_\-\n\r]/g, " ")
      .trim()
      .length / 420
  )
);
const topic = post.data.topic || post.data.categories[0] || "研究记录";
const routeTags = [
  ...relatedSectors.map((sector) => ({
    label: sector.title,
    href: `/sectors/${sector.slug}/`,
    soft: false
  })),
  ...post.data.categories.map((category: string) => ({
    label: category,
    href: `/categories/${encodeURIComponent(category)}/`,
    soft: false
  })),
  ...post.data.tags.map((tag: string) => ({
    label: `#${tag}`,
    href: `/tags/${encodeURIComponent(tag)}/`,
    soft: true
  }))
].slice(0, 6);
---

<article class="article-shell">
  <div class="article-hero panel">
    <div class="article-hero__grid">
      <div class="article-hero__copy">
        <div class="article-path">
          <a href="/blog">博客</a>
          <span>/</span>
          <span>{sourceLabel}</span>
        </div>
        <span class="eyebrow eyebrow--muted">{topic}</span>
        <div class="article-hero__status">
          <span class="status-pill status-pill--accent">{dossierLabel}</span>
          <span class="status-pill">{readingMinutes} 分钟阅读</span>
          <span class="status-pill">{post.data.pubDate.toISOString().slice(0, 10)}</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="article-summary">{post.data.description}</p>
      </div>

      <aside class="article-specs article-specs--dossier">
        <div class="article-specs__head">
          <span class="archive-card__stamp">{dossierLabel}</span>
          <span class="card-kicker">Article Brief</span>
          <p>{sourceDescription}</p>
        </div>

        <dl class="article-spec-list">
          <div class="article-spec">
            <dt>发布日期</dt>
            <dd>{post.data.pubDate.toISOString().slice(0, 10)}</dd>
          </div>
          <div class="article-spec">
            <dt>阅读时长</dt>
            <dd>{readingMinutes} 分钟</dd>
          </div>
          <div class="article-spec">
            <dt>内容来源</dt>
            <dd>{sourceLabel}</dd>
          </div>
          <div class="article-spec">
            <dt>研究主题</dt>
            <dd>{topic}</dd>
          </div>
        </dl>
      </aside>
    </div>

    <div class="article-route-panel">
      <div class="article-route-panel__head">
        <span class="card-kicker">关联路径</span>
        <p>从所属战区和主题分卷继续扩展阅读，而不是只停在单篇卷宗里。</p>
      </div>
      <div class="article-taxonomy">
        {routeTags.map((route) => (
          <a class={`meta-chip ${route.soft ? "meta-chip--soft" : ""}`} href={route.href}>
            {route.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="article-body panel">
    <slot />
  </div>
</article>
